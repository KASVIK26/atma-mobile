# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ============================================================================
# DEPENDENCIES & BUILD
# ============================================================================
node_modules/
npm-debug.*
yarn-debug.*
yarn-error.*
*.tsbuildinfo

# ============================================================================
# EXPO & NATIVE BUILD ARTIFACTS
# ============================================================================
.expo/
dist/
web-build/
.metro-health-check*

# Native build outputs (keep local, ignore remote)
/android/
/ios/
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# ============================================================================
# ENVIRONMENT & SECRETS
# ============================================================================
.env
.env.local
.env.*.local
.env.example  # Optional: remove if you want to track defaults

# ============================================================================
# IDE & EDITOR SPECIFIC
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride
*.iml

# ============================================================================
# TEMPORARY & BACKUP FILES
# ============================================================================
app-example
app.json.bak
*.bak
*.tmp
*.swp
*.orig
package-lock.json  # Optional: uncomment if using npm workspaces
yarn.lock         # Optional: uncomment if using yarn

# ============================================================================
# PLATFORM SPECIFIC
# ============================================================================
# macOS
.DS_Store
*.pem
Thumbs.db           # Windows

# ============================================================================
# OPTIONAL: Generated files (uncomment if needed)
# ============================================================================
# expo-env.d.ts     # Generated by Expo - uncomment to ignore
# Icons_Android/    # Platform specific - uncomment to ignore
# ui-designs/       # Design files - uncomment to ignore
