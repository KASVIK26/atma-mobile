# ============================================================================
# AUTHENTICATION & DATABASE
# ============================================================================

# Supabase Project Configuration
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# JWT Secret (for token verification on client, optional)
EXPO_PUBLIC_JWT_SECRET=your_jwt_secret_here

# ============================================================================
# APP CONFIGURATION
# ============================================================================

# App Environment
EXPO_PUBLIC_ENV=development
EXPO_PUBLIC_DEBUG=true

# API Base URL
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Geofencing
EXPO_PUBLIC_GEOFENCE_ENABLED=true
EXPO_PUBLIC_GEOFENCE_RADIUS_METERS=50

# Barometric Pressure Validation
EXPO_PUBLIC_PRESSURE_VALIDATION_ENABLED=true
EXPO_PUBLIC_PRESSURE_THRESHOLD_HPA=2

# TOTP Authentication
EXPO_PUBLIC_TOTP_ENABLED=true
EXPO_PUBLIC_TOTP_DURATION_SECONDS=30

# Proxy Detection
EXPO_PUBLIC_PROXY_DETECTION_ENABLED=true
EXPO_PUBLIC_CONFIDENCE_THRESHOLD=0.75

# ============================================================================
# NOTIFICATIONS
# ============================================================================

# Push Notifications (optional)
EXPO_PUBLIC_PUSH_ENABLED=false
EXPO_PUBLIC_FCM_SENDER_ID=your_fcm_sender_id

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Error Reporting (optional)
EXPO_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
EXPO_PUBLIC_LOG_LEVEL=info

# ============================================================================
# COMPLIANCE & SECURITY
# ============================================================================

# Data Retention (days)
EXPO_PUBLIC_SENSOR_DATA_RETENTION_DAYS=90
EXPO_PUBLIC_AUDIT_LOG_RETENTION_DAYS=365

# Rate Limiting
EXPO_PUBLIC_AUTH_RATE_LIMIT_ATTEMPTS=5
EXPO_PUBLIC_AUTH_RATE_LIMIT_WINDOW_MINUTES=15
# ============================================================================
# ERROR MONITORING (Sentry)
# ============================================================================

# Get your DSN from https://sentry.io — Project > Settings > Client Keys (DSN)
# Leave empty to disable Sentry during local development.
EXPO_PUBLIC_SENTRY_DSN=