{
  "expo": {
    "name": "ATMA",
    "slug": "atma-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ATMA-inApp.png",
    "scheme": "atmamobile",
    "userInterfaceStyle": "automatic",
    "description": "ATMA — Automated Technology for Master Attendance. Smart attendance tracking for universities.",
    "primaryColor": "#2563EB",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to verify your attendance at the classroom",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We need your location to verify your attendance at the classroom",
        "NSLocationAlwaysUsageDescription": "We need your location to verify your attendance at the classroom",
        "NSMotionUsageDescription": "We need access to your device's barometer (pressure sensor) to verify your location on the correct floor",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.kasvik26.atmamobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.BODY_SENSORS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.BODY_SENSORS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.BODY_SENSORS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.BODY_SENSORS"
      ],
      "package": "com.kasvik26.atmamobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/withAndroidKeyboard",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/ATMA-LOGO.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/ATMA-LOGO.png",
            "backgroundColor": "#0E0E0E"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9ebbc8d2-abf4-4efb-b2d1-a7a940b8fdb5"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/35c21197-241e-4d6c-9f03-edf231dfc8aa"
    },
    "owner": "kasvik2603"
  }
}
